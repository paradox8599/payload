{
  "name": "blank-payload",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .git-hooks",
    "clean": "rm -rf .next node_modules",
    "dev": "next dev",
    "devsafe": "rm -rf .next && next dev",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "generate:db-schema": "payload generate:db-schema",
    "gen": "bun generate:importmap && bun generate:types",
    "build": "next build",
    "build:standalone": "NEXT_OUTPUT=standalone next build",
    "start": "next start",
    "lint": "next lint",
    "payload": "payload"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.20.0",
    "@payloadcms/db-vercel-postgres": "^3.20.0",
    "@payloadcms/email-resend": "^3.20.0",
    "@payloadcms/next": "^3.20.0",
    "@payloadcms/payload-cloud": "^3.20.0",
    "@payloadcms/richtext-lexical": "^3.20.0",
    "@payloadcms/storage-s3": "^3.20.0",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.10.0",
    "lucide-react": "^0.474.0",
    "next": "^15.1.6",
    "payload": "^3.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.3",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.1.6",
    "eslint-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "react-is": "^19"
  }
}
