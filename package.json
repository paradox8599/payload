{
  "name": "blank-payload",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .git-hooks",
    "clean": "rm -rf .next node_modules",
    "dev": "next dev",
    "devsafe": "rm -rf .next && next dev",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "generate:db-schema": "payload generate:db-schema",
    "gen": "bun generate:importmap && bun generate:types",
    "build": "next build",
    "build:standalone": "NEXT_OUTPUT=standalone next build",
    "start": "next start",
    "lint": "next lint",
    "payload": "payload"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.23.0",
    "@payloadcms/db-vercel-postgres": "^3.23.0",
    "@payloadcms/email-resend": "^3.23.0",
    "@payloadcms/next": "^3.23.0",
    "@payloadcms/payload-cloud": "^3.23.0",
    "@payloadcms/richtext-lexical": "^3.23.0",
    "@payloadcms/storage-s3": "^3.23.0",
    "graphql": "^16.10.0",
    "next": "^15.1.7",
    "payload": "^3.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "babel-plugin-react-compiler": "^19.0.0-beta-30d8a17-20250209",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.1.7",
    "eslint-plugin-react-compiler": "^19.0.0-beta-30d8a17-20250209",
    "postcss": "^8.5.2",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.5.1",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
